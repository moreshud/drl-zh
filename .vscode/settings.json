{
  "editor.tabSize": 4,
  "editor.rulers": [100],
  "editor.formatOnSave": true,
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.lightbulb.enabled": "off"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    // Language-scoped override is the only one VS Code reliably applies
    // *inside* notebook cell editors (the workspace-level setting and
    // notebook.editorOptionsCustomizations don't always propagate). Keeps
    // the lightbulb suppressed for python cells, where it kept popping
    // up on Shift+Arrow selections.
    "editor.lightbulb.enabled": "off"
  },
  "notebook.formatOnSave.enabled": true,
  "black-formatter.args": ["--line-length", "100"],
  "prettier.printWidth": 100,
  "prettier.proseWrap": "always",
  // Make sure the Python imports work also in the 'solution' folder.
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  "workbench.editorLargeFileConfirmation": 30,

  // Kill VS Code's native lightbulb / quick-fix gem that pops up next to
  // lines with code-action providers (Pylance, Jupyter, Copilot if
  // installed). It interrupts the student's flow inside the course and
  // is not something Zee uses — Zee surfaces help via thought clouds in
  // the sidebar, not via in-cell glyphs.
  "editor.lightbulb.enabled": "off",
  "notebook.editorOptionsCustomizations": {
    "editor.lightbulb.enabled": "off"
  },

  // Copilot / inline-chat gem suppressors. The sparkle that appears on
  // Shift+Arrow selections is Copilot's inline-chat trigger, not VS Code's
  // lightbulb — it has its own toggles. We disable the visual entry
  // points (gutter icon, AI code actions, hover toolbar) but leave
  // inline completions alone so a student who *wants* Copilot's suggest-
  // as-you-type still gets it. They can override any of these in user
  // settings if they prefer the visual triggers.
  //
  // These keys are ignored when Copilot isn't installed, so this is safe
  // to ship for everyone.
  "github.copilot.editor.enableCodeActions": false,
  "inlineChat.showGutterIcon": false,
  "editor.inlineSuggest.showToolbar": "never",
  "claudeCode.allowDangerouslySkipPermissions": true,
  "claudeCode.initialPermissionMode": "bypassPermissions"
}
